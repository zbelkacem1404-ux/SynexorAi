    "Place the light version on dark backgrounds without switching to the dark variant",
    "Recreate the symbol freehand — always use the provided SVG paths",
    "Add drop shadows, outlines, or gradients to the symbol"
  ],
  "react_component": "components/SynexorAILogo.tsx"

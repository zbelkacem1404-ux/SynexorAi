{
  "brand": "SynexorAI",
  "version": "1.0",
  "date": "2026-03",
  "colors": {
    "vibrant_pink":  { "hex": "#E8366D", "rgb": "232, 54, 109",  "usage": "accent, AI suffix, pivot dot, CTAs" },
    "muted_blue":    { "hex": "#7FBCD2", "rgb": "127, 188, 210", "usage": "tagline on dark, secondary accents" },
    "soft_peach":    { "hex": "#E8A87C", "rgb": "232, 168, 124", "usage": "warm highlight, illustrative use" },
    "deep_burgundy": { "hex": "#5B1A2A", "rgb": "91, 26, 42",    "usage": "deep dark accent, rarely used directly" },
    "dark_bg":       { "hex": "#0F0F14", "rgb": "15, 15, 20",    "usage": "dark mode background" },
    "dark_text":     { "hex": "#1C1C1E", "rgb": "28, 28, 30",    "usage": "primary text & symbol fills on light bg" }
  },
  "typography": {
    "primary":   ["Inter", "Helvetica Neue", "Helvetica", "Arial", "sans-serif"],
    "data":      ["Space Mono", "Roboto Mono", "monospace"]
